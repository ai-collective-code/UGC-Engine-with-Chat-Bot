# Copy to .env, fill in real values, never commit this file.

# --- WhatsApp Cloud API (bulk sender: scripts/send_whatsapp.py) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en_US

# --- WhatsApp AI Agent (scripts/whatsapp_ai_agent.py) ---
# Reuses WHATSAPP_ACCESS_TOKEN + WHATSAPP_PHONE_NUMBER_ID above, plus:
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
ANTHROPIC_API_KEY=
# Optional: which client config the negotiator uses (default: config/myk_laticrete.json)
CLIENT_CONFIG=

# --- Instagram Messaging (scripts/instagram_webhook.py) ---
# Runs the same Claude negotiator as the WhatsApp agent above; reuses
# ANTHROPIC_API_KEY / CLIENT_CONFIG.
IG_ACCESS_TOKEN=
IG_VERIFY_TOKEN=
IG_APP_SECRET=

# --- Apify scraping (backend/app.py "Scrape from Instagram") ---
# API token from Apify Console > Settings > Integrations. Enables in-app
# Instagram scraping via the apify/instagram-reel-scraper actor. Costs Apify
# credits per run (~$2.60 / 1,000 reels). Never commit the real value.
APIFY_TOKEN=
# Optional: override the actor (default: apify~instagram-reel-scraper)
APIFY_INSTAGRAM_ACTOR=xMc5Ga1oCONPmWJIa

# --- Emergency stop (lib/llm_negotiator.py) ---
# Set to true/1/yes to instantly disable the AI on every channel (WhatsApp +
# Instagram) and fall back to a fixed "our team will follow up" reply, with
# no code or credential changes. Unset (or false) for normal operation.
NEGOTIATOR_PAUSED=

# --- Shop verification dialer (backend/app.py "Shop Verify") ---
# Google Maps Places API key: auto-sources nearby tile/hardware shops (name +
# phone) for a finalized creator's location. Enable "Places API (New)" + billing
# in Google Cloud. If unset, the tab still works — you just paste shop numbers.
GOOGLE_MAPS_API_KEY=
# Cloud telephony for click-to-call bridging (optional). If unset, the dashboard
# hands the agent a tel: link to dial on their own phone/softphone instead.
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_CALLER_ID=
AGENT_PHONE=

# --- Instagram AI Agent bridge (unified inbox) ---
# Base URL of the live Next.js chatbot. The UGC Conversations tab reads
# Instagram DMs from, and sends replies through, its HTTP API. No database
# credentials needed here. Default is the chatbot's local dev port.
INSTAGRAM_CHATBOT_URL=http://localhost:3000

# --- Database (lib/local_db.py) ---
# PostgreSQL connection string. The engine keeps all its data in a dedicated
# `ugc` schema, so it can safely share a database with other apps. Locally use
# the EXTERNAL Render URL; on Render use the INTERNAL URL (same-region/faster).
DATABASE_URL=postgresql://user:password@host.oregon-postgres.render.com/dbname
# libpq sslmode; default "require". Set "disable" for a local Postgres w/o SSL.
PGSSLMODE=require
