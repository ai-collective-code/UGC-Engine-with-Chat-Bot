# Instagram AI Agent — environment configuration
# Copy to .env and fill in real values. Never commit .env.

# --- Instagram Graph API (required) ---
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_VERIFY_TOKEN=your_webhook_verify_token
# App secret from Meta App Dashboard — enables X-Hub-Signature-256 webhook
# verification. REQUIRED in production; without it, forged webhook payloads
# are accepted.
INSTAGRAM_APP_SECRET=your_meta_app_secret

# --- Facebook Messenger (optional, same Meta app) ---
# Messenger runs through the SAME /api/webhook and the same negotiation flow as
# Instagram — set these to also serve a Facebook Page. FACEBOOK_ACCESS_TOKEN is
# the Page access token. Verify token / app secret can be omitted if the
# INSTAGRAM_* ones are set (both are accepted, since it's one Meta app).
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=

# --- AI models ---
# Primary: Gemini direct (free tier via Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
# Fallback chain: OpenRouter (free-tier models)
OPENROUTER_API_KEY=your_openrouter_api_key
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Database: Render PostgreSQL (required) ---
# Full connection string from the Render dashboard (Databases → your DB →
# "External Database URL"). SSL is required and handled in code. This is the
# ONLY database credential the app needs — it is used server-side only and is
# never exposed to the browser.
DATABASE_URL=postgresql://user:password@host.oregon-postgres.render.com/dbname

# --- Realtime: Ably (optional but recommended) ---
# Enables instant dashboard updates (push) instead of the 15s safety-net poll.
# Server-side only — the browser authenticates via /api/ably-auth and never
# sees this key. Get a free key at https://ably.com (root key is fine).
# If unset, the app still works and updates arrive within ~15s via polling.
ABLY_API_KEY=your_ably_api_key

# --- App ---
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
